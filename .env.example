# =====================================================
# Ameen Academy - Environment Variables
# =====================================================
# انسخ هذا الملف لـ .env وقم بملء القيم

# قاعدة البيانات (Neon PostgreSQL)
# احصل عليها من: https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# المصادقة (NextAuth)
# للحصول على secret: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-min-32-chars"
AUTH_URL="http://localhost:3000"

# Google OAuth (اختياري)
# https://console.cloud.google.com
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Bunny Stream (للفيديوهات)
# https://bunny.net
BUNNY_STREAM_LIBRARY_ID=""
BUNNY_STREAM_API_KEY=""
BUNNY_STREAM_CDN_HOSTNAME=""
BUNNY_STREAM_SECURITY_KEY=""

# Bunny Storage (للصور)
BUNNY_STORAGE_ZONE_NAME=""
BUNNY_STORAGE_API_KEY=""
BUNNY_STORAGE_CDN_HOSTNAME=""

# Paymob (بوابة الدفع - مصر)
# https://accept.paymob.com
PAYMOB_API_KEY=""
PAYMOB_INTEGRATION_ID_CARD=""
PAYMOB_INTEGRATION_ID_WALLET=""
PAYMOB_IFRAME_ID=""
PAYMOB_HMAC_SECRET=""

# Vercel Blob (تخزين الصور المرفوعة — حلول البريف/المدونة/البروفايل)
# بيتولّد تلقائياً لما تعمل Blob Store في Vercel وتربطه بالمشروع
BLOB_READ_WRITE_TOKEN=""

# Google Gemini (الذكاء الاصطناعي — توليد البريف + فيدباك التصميم)
# مفتاح مجاني من: https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# البريد الإلكتروني (Resend)
# https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="Ameen Academy <noreply@ameen.academy>"

# عام
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Ameen Academy"

# ============ Web Push (VAPID) — توليد المفاتيح: npx web-push generate-vapid-keys ============
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@ameen.academy
