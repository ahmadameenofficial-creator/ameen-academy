// =====================================================
// Ameen Academy - Database Schema
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ============ Leads (المهتمين بالكورس المجاني) ============
model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String? // واتساب
  email     String?
  source    String   @default("free-course") // مصدر الـ lead
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
  @@index([phone])
}

// ============ المستخدمين ============
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  password        String? // hashed - null لمستخدمي OAuth
  name            String
  image           String?
  bio             String?   @db.Text
  phone           String?
  role            Role      @default(STUDENT)
  isBanned        Boolean   @default(false)
  bannedReason    String?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // نظام الإحالة (Affiliate)
  referralCode    String?   @unique // كود الإحالة الخاص بالمستخدم
  referredById    String? // مين أحاله للمنصة

  // العلاقات
  accounts        Account[]
  sessions        Session[]
  enrollments     Enrollment[]
  progress        LessonProgress[]
  posts           Post[]
  comments        Comment[]
  likes           Like[]
  reactions       Reaction[]
  notifications   Notification[]
  ratings         Rating[]
  payments        Payment[]
  certificates    Certificate[]
  videoTokens     VideoToken[]
  loginAttempts   LoginAttempt[]
  coursesCreated  Course[]         @relation("CourseInstructor")
  blogPosts       BlogPost[]       @relation("BlogAuthor")
  blogComments    BlogComment[]    @relation("BlogCommentAuthor")
  blogLikes       BlogLike[]       @relation("BlogLikeUser")

  // الرسائل المباشرة
  conversationsAsP1 Conversation[] @relation("ConversationP1")
  conversationsAsP2 Conversation[] @relation("ConversationP2")
  sentMessages      Message[]      @relation("MessageSender")

  // علاقات الإحالة
  referredBy      User?            @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals       User[]           @relation("UserReferrals")
  commissions     Commission[]     @relation("CommissionReferrer")

  // منصة البريف (Ameen.academy/brief)
  briefsCreated    Brief[]           @relation("BriefCreator")
  briefSubmissions BriefSubmission[]
  briefVotes       BriefVote[]
  designerStats    DesignerStats?
  designerBadges   DesignerBadge[]

  @@index([email])
  @@index([role])
  @@index([referredById])
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

// ============ NextAuth ============
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

// ============ تتبع محاولات الدخول (أمان) ============
model LoginAttempt {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  ipAddress String?
  userAgent String?
  success   Boolean
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

// ============ الكورسات ============
model Course {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String   @db.Text
  shortDescription String?
  thumbnail       String?
  trailerVideoId  String?
  category        String
  level           Level    @default(BEGINNER)
  language        String   @default("ar")
  price           Int      // بالقرش (499 جنيه = 49900)
  comparePrice    Int?     // السعر قبل الخصم
  duration        Int      @default(0) // إجمالي بالثواني
  isPublished     Boolean  @default(false)
  isFeatured      Boolean  @default(false)
  publishedAt     DateTime?
  instructorId    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  instructor    User           @relation("CourseInstructor", fields: [instructorId], references: [id])
  modules       Module[]
  lessons       Lesson[]
  enrollments   Enrollment[]
  posts         Post[]
  ratings       Rating[]
  payments      Payment[]
  certificates  Certificate[]
  coupons       Coupon[]

  @@index([isPublished, isFeatured])
  @@index([instructorId])
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// ============ الموديولات (مجموعات دروس) ============
model Module {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?  @db.Text
  order       Int
  createdAt   DateTime @default(now())

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId, order])
}

// ============ الدروس ============
model Lesson {
  id            String     @id @default(cuid())
  courseId      String
  moduleId      String?
  title         String
  description   String?    @db.Text
  videoId       String?    // Bunny Stream Video ID
  duration      Int        @default(0) // بالثواني
  order         Int
  isFree        Boolean    @default(false) // متاحة للمعاينة
  attachments   Json?      // [{name, url, size}]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module      Module?          @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  progress    LessonProgress[]
  videoTokens VideoToken[]

  @@index([courseId, order])
}

// ============ تسجيل الطلاب ============
model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  expiresAt   DateTime? // اختياري للوصول المؤقت

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

// ============ تتبع التقدم ============
model LessonProgress {
  id              String    @id @default(cuid())
  userId          String
  lessonId        String
  isCompleted     Boolean   @default(false)
  watchedSeconds  Int       @default(0)
  lastPosition    Int       @default(0) // resume watching
  watchCount      Int       @default(0)
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([userId, isCompleted])
  @@index([lessonId])
}

// ============ توكنات الفيديو (للأمان) ============
model VideoToken {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  token     String   @unique
  ipAddress String?
  expiresAt DateTime
  usedCount Int      @default(0)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

// ============ المدفوعات ============
model Payment {
  id              String        @id @default(cuid())
  userId          String
  courseId        String
  amount          Int           // بالقرش
  currency        String        @default("EGP")
  status          PaymentStatus @default(PENDING)
  method          String?       // card, wallet, fawry
  paymobOrderId   String?       @unique
  paymobTxnId     String?       @unique
  couponCode      String?
  discount        Int           @default(0) // مبلغ الخصم بالقرش
  metadata        Json?
  createdAt       DateTime      @default(now())
  paidAt          DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  commission Commission?

  @@index([userId])
  @@index([status])
  @@index([status, createdAt])
  @@index([userId, courseId, status])
}

// ============ عمولات الإحالة (Affiliate Commissions) ============
model Commission {
  id             String           @id @default(cuid())
  referrerId     String // المستخدم اللي بياخد العمولة
  referredUserId String // المستخدم اللي اشترى
  paymentId      String           @unique // عمولة واحدة لكل دفعة (يمنع الازدواج)
  amount         Int // العمولة بالقرش
  rate           Int // نسبة العمولة وقت التسجيل (%)
  status         CommissionStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  paidAt         DateTime?

  referrer User    @relation("CommissionReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  payment  Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([referrerId, status])
  @@index([status, createdAt])
}

enum CommissionStatus {
  PENDING // مستحقة
  PAID // اتدفعت
  CANCELLED // اتلغت (مثلاً استرجاع)
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    @default("percentage") // percentage | fixed
  discountValue Int       // نسبة مئوية أو مبلغ بالقرش
  maxUses       Int?      // null = unlimited
  usedCount     Int       @default(0)
  minPrice      Int?      // أقل مبلغ للتطبيق (بالقرش)
  courseId      String?   // null = ينطبق على كل الكورسات
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  course Course? @relation(fields: [courseId], references: [id])
}

// ============ التقييمات ============
model Rating {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  rating    Int      // 1-5
  comment   String?  @db.Text
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

// ============ المجتمع ============
model Post {
  id            String   @id @default(cuid())
  userId        String
  courseId      String?  // اختياري - منشور في كورس معين
  content       String   @db.Text
  image         String?
  mediaUrl      String?   // رابط الصورة أو الفيديو
  mediaType     String?   // "image" أو "video"
  likesCount    Int      @default(0)
  commentsCount Int      @default(0)
  isPinned      Boolean  @default(false)
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course?    @relation(fields: [courseId], references: [id], onDelete: SetNull)
  comments  Comment[]
  likes     Like[]
  reactions Reaction[]

  @@index([courseId, createdAt])
  @@index([userId])
  @@index([isDeleted, isPinned, createdAt])
}

model Comment {
  id         String   @id @default(cuid())
  postId     String
  userId     String
  parentId   String?  // للردود على كومنت
  content    String   @db.Text
  likesCount Int      @default(0)
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  post      Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]  @relation("CommentReplies")
  likes     Like[]
  reactions Reaction[]

  @@index([postId])
  @@index([parentId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String?
  commentId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
}

model Reaction {
  id        String   @id @default(cuid())
  userId    String
  postId    String?
  commentId String?
  type      String   // "like" | "love" | "haha" | "wow" | "sad"
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([postId, type])
  @@index([commentId])
}

// ============ الإشعارات ============
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String?          @db.Text
  link      String?
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

enum NotificationType {
  LIKE
  COMMENT
  ENROLLMENT
  COURSE_UPDATE
  NEW_LESSON
  CERTIFICATE
  PAYMENT_SUCCESS
  SYSTEM
  MESSAGE
}

// ============ الشهادات ============
model Certificate {
  id              String   @id @default(cuid())
  userId          String
  courseId        String
  certificateCode String   @unique
  issuedAt        DateTime @default(now())
  pdfUrl          String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

// ============ المدونة ============
model BlogPost {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String?   @db.Text // ملخص قصير للمقال
  content       String    @db.Text // المحتوى بالـ Markdown
  thumbnail     String?
  category      String    // مثلاً: "تصميم", "AI", "فريلانس", "مهارات"
  tags          String[]  // كلمات مفتاحية
  authorId      String
  isPublished   Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  viewsCount    Int       @default(0)
  readingTime   Int       @default(0) // بالدقايق
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  author       User          @relation("BlogAuthor", fields: [authorId], references: [id])
  comments     BlogComment[]
  likes        BlogLike[]

  @@index([isPublished, isFeatured, publishedAt])
  @@index([category])
  @@index([slug])
}

model BlogComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  parentId  String?
  content   String   @db.Text
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User          @relation("BlogCommentAuthor", fields: [userId], references: [id], onDelete: Cascade)
  parent  BlogComment?  @relation("BlogCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies BlogComment[] @relation("BlogCommentReplies")

  @@index([postId, createdAt])
  @@index([parentId])
}

model BlogLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation("BlogLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

// ============ الرسائل المباشرة (DMs) ============
model Conversation {
  id            String    @id @default(cuid())
  participant1Id String
  participant2Id String
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())

  participant1  User      @relation("ConversationP1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2  User      @relation("ConversationP2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages      Message[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id, lastMessageAt])
  @@index([participant2Id, lastMessageAt])
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  senderId        String
  content         String   @db.Text
  image           String?  // رابط صورة مرفقة (اختياري)
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ============ سجل أفعال الأدمن (Audit Log) ============
model AuditLog {
  id        String   @id @default(cuid())
  userId    String // الأدمن اللي عمل الفعل
  action    String // مثلاً: "payment.approve", "student.ban", "course.delete"
  target    String? // ID الحاجة اللي اتأثرت
  details   String? @db.Text // تفاصيل إضافية (JSON أو نص)
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// =====================================================
// ============ VIP Community (الاشتراك الشهري) ============
// =====================================================

// طلبات الانضمام للـ VIP
model VipApplication {
  id          String   @id @default(cuid())
  userId      String?  // لو مسجّل بالفعل
  name        String
  email       String
  phone       String
  experience  String   @db.Text // مستوى الخبرة الحالي
  currentWork String   @db.Text // بيشتغل في إيه دلوقتي
  goal        String   @db.Text // إيه هدفه من VIP
  status      VipApplicationStatus @default(PENDING)
  reviewNotes String?  @db.Text
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([status, createdAt])
  @@index([email])
}

enum VipApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  ENROLLED  // قبل ودفع
}

// عضويات الـ VIP (الفعّالين)
model VipMembership {
  id            String   @id @default(cuid())
  userId        String   @unique
  plan          VipPlan  @default(MONTHLY)
  status        VipStatus @default(ACTIVE)
  startedAt     DateTime @default(now())
  currentPeriodEnd DateTime
  cancelledAt   DateTime?
  totalPaid     Int      @default(0) // بالقرش

  // الـ hot seat - دور كل عضو
  hotSeatOrder  Int      @default(0)
  hadHotSeats   Int      @default(0)

  @@index([status, currentPeriodEnd])
}

enum VipPlan {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum VipStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

// اللايف ستريم اللي بيتعمل كل أسبوعين
model VipLive {
  id            String   @id @default(cuid())
  title         String
  description   String?  @db.Text
  scheduledAt   DateTime
  durationMins  Int      @default(90)
  meetingUrl    String?  // Zoom/Google Meet
  recordingUrl  String?  // اللينك بعد ما يتسجّل
  hotSeatUserId String?  // مين هياخد الـ hot seat اللايف ده
  status        VipLiveStatus @default(SCHEDULED)
  createdAt     DateTime @default(now())

  @@index([scheduledAt])
  @@index([status, scheduledAt])
}

enum VipLiveStatus {
  SCHEDULED
  LIVE
  RECORDED
  CANCELLED
}

// الـ briefs الشهرية
model VipBrief {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  clientStyle String   @db.Text // الـ brief بأسلوب client (الفعلي)
  deliverables String  @db.Text // اللي مطلوب يتسلّم
  dueDate     DateTime
  publishedAt DateTime @default(now())
  attachments String?  @db.Text // JSON of refs

  @@index([publishedAt])
}

// الـ resources المتاحة للأعضاء
model VipResource {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  category    String   // mockups, fonts, contracts, scripts, etc
  fileUrl     String
  thumbnailUrl String?
  downloadCount Int    @default(0)
  publishedAt DateTime @default(now())

  @@index([category, publishedAt])
}

// الـ job board
model VipJob {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  budget      String   // text عشان نقدر نكتب "500-1000 ج" مثلاً
  type        String   // freelance, full-time, contract
  clientInfo  String?  // معلومات عن العميل
  contactInfo String   // إزاي يتواصلوا
  postedAt    DateTime @default(now())
  expiresAt   DateTime
  filledAt    DateTime?

  @@index([postedAt])
  @@index([expiresAt])
}

// =====================================================
// ============ منصة البريف (Ameen.academy/brief) ============
// منصة عامة مجانية لتدريب المصممين على بريفات واقعية
// =====================================================

enum BriefType {
  LOGO            // تصميم شعار
  SOCIAL_POST     // بوست سوشيال ميديا
  BRAND_IDENTITY  // هوية بصرية كاملة
}

enum BriefLevel {
  BEGINNER
  INTERMEDIATE
  PRO
}

enum BriefSource {
  TEMPLATE // اتولّد من محرك القوالب
  AI       // اتولّد بمساعدة Gemini
}

enum SubmissionStatus {
  PUBLISHED
  HIDDEN
  FLAGGED
}

// البريف المنشور (صفحة SEO لكل بريف)
model Brief {
  id               String      @id @default(cuid())
  slug             String      @unique
  type             BriefType
  level            BriefLevel  @default(BEGINNER)
  source           BriefSource @default(TEMPLATE)
  clientName       String      // اسم العميل الوهمي
  clientBusiness   String      // اسم النشاط (مثلاً: مطعم كشري المعادي)
  businessCategory String      // فئة النشاط (مطاعم، عيادات، أزياء...)
  title            String      // عنوان البريف
  scenario         String      @db.Text // السرد الكامل بنبرة العميل
  audience         String      @db.Text // الجمهور المستهدف
  brandTone        String      // نبرة البراند
  constraints      Json        // {budget, deadline, forbiddenColors, notes}
  deliverables     Json        // [{name, format, size}]
  details          Json?       // {goal, keyMessage, copy{headline,subline,cta,hashtag}, mustInclude[], moodKeywords[], dos[], donts[]}
  createdById      String?     // مين ولّده (null = توليد مجهول/مبدئي)
  isPublished      Boolean     @default(true)
  isFeatured       Boolean     @default(false)
  viewsCount       Int         @default(0)
  challengeId      String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  createdBy   User?            @relation("BriefCreator", fields: [createdById], references: [id], onDelete: SetNull)
  challenge   BriefChallenge?  @relation(fields: [challengeId], references: [id], onDelete: SetNull)
  submissions BriefSubmission[]

  @@index([isPublished, isFeatured, createdAt])
  @@index([type, level])
  @@index([createdById])
  @@index([challengeId])
}

// حل المصمم لبريف
model BriefSubmission {
  id             String           @id @default(cuid())
  briefId        String
  userId         String
  imageUrl       String           // الصورة على Bunny Storage
  thumbnailUrl   String?
  note           String?          @db.Text // ملاحظات المصمم على حله
  votesCount     Int              @default(0)
  aiScore        Int?             // تقييم AI (0-100)
  aiFeedback     Json?            // ملاحظات Gemini المنظمة
  expertFeedback String?          @db.Text // فيدباك خبير/أدمن
  status         SubmissionStatus @default(PUBLISHED)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  brief Brief       @relation(fields: [briefId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes BriefVote[]

  @@index([briefId, status, createdAt])
  @@index([userId])
  @@index([status, votesCount])
}

// تصويت على حل
model BriefVote {
  id           String   @id @default(cuid())
  submissionId String
  userId       String
  createdAt    DateTime @default(now())

  submission BriefSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([submissionId, userId])
  @@index([userId])
}

// إحصائيات المصمم (gamification) — 1:1 مع User
model DesignerStats {
  id            String    @id @default(cuid())
  userId        String    @unique
  xp            Int       @default(0)
  level         Int       @default(1)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastSolvedAt  DateTime?
  briefsSolved  Int       @default(0)
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([xp])
}

// تعريف الشارات
model BriefBadge {
  id          String   @id @default(cuid())
  key         String   @unique // معرّف ثابت (first_brief, logo_master...)
  name        String
  description String
  icon        String   // اسم أيقونة Tabler
  threshold   Json     // معيار الحصول عليها
  createdAt   DateTime @default(now())

  designers DesignerBadge[]
}

// شارات المصمم (join)
model DesignerBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge BriefBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

// التحديات الأسبوعية/الشهرية
model BriefChallenge {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  theme       String
  description String     @db.Text
  type        BriefType?
  startsAt    DateTime
  endsAt      DateTime
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  briefs Brief[]

  @@index([isActive, endsAt])
}
