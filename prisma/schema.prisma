// =====================================================
// Ameen Academy - Database Schema
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ============ Leads (المهتمين بالكورس المجاني) ============
model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String? // واتساب
  email     String?
  source    String   @default("free-course") // مصدر الـ lead
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
  @@index([phone])
}

// ============ المستخدمين ============
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  password        String? // hashed - null لمستخدمي OAuth
  name            String
  image           String?
  bio             String?   @db.Text
  phone           String?
  role            Role      @default(STUDENT)
  isBanned        Boolean   @default(false)
  bannedReason    String?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // نظام الإحالة (Affiliate)
  referralCode    String?   @unique // كود الإحالة الخاص بالمستخدم
  referredById    String? // مين أحاله للمنصة

  // العلاقات
  accounts        Account[]
  sessions        Session[]
  enrollments     Enrollment[]
  progress        LessonProgress[]
  posts           Post[]
  comments        Comment[]
  likes           Like[]
  reactions       Reaction[]
  notifications   Notification[]
  ratings         Rating[]
  payments        Payment[]
  certificates    Certificate[]
  videoTokens     VideoToken[]
  loginAttempts   LoginAttempt[]
  coursesCreated  Course[]         @relation("CourseInstructor")
  blogPosts       BlogPost[]       @relation("BlogAuthor")
  blogComments    BlogComment[]    @relation("BlogCommentAuthor")
  blogLikes       BlogLike[]       @relation("BlogLikeUser")

  // علاقات الإحالة
  referredBy      User?            @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals       User[]           @relation("UserReferrals")
  commissions     Commission[]     @relation("CommissionReferrer")

  @@index([email])
  @@index([role])
  @@index([referredById])
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

// ============ NextAuth ============
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

// ============ تتبع محاولات الدخول (أمان) ============
model LoginAttempt {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  ipAddress String?
  userAgent String?
  success   Boolean
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

// ============ الكورسات ============
model Course {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String   @db.Text
  shortDescription String?
  thumbnail       String?
  trailerVideoId  String?
  category        String
  level           Level    @default(BEGINNER)
  language        String   @default("ar")
  price           Int      // بالقرش (499 جنيه = 49900)
  comparePrice    Int?     // السعر قبل الخصم
  duration        Int      @default(0) // إجمالي بالثواني
  isPublished     Boolean  @default(false)
  isFeatured      Boolean  @default(false)
  publishedAt     DateTime?
  instructorId    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  instructor    User           @relation("CourseInstructor", fields: [instructorId], references: [id])
  modules       Module[]
  lessons       Lesson[]
  enrollments   Enrollment[]
  posts         Post[]
  ratings       Rating[]
  payments      Payment[]
  certificates  Certificate[]
  coupons       Coupon[]

  @@index([isPublished, isFeatured])
  @@index([instructorId])
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// ============ الموديولات (مجموعات دروس) ============
model Module {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?  @db.Text
  order       Int
  createdAt   DateTime @default(now())

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId, order])
}

// ============ الدروس ============
model Lesson {
  id            String     @id @default(cuid())
  courseId      String
  moduleId      String?
  title         String
  description   String?    @db.Text
  videoId       String?    // Bunny Stream Video ID
  duration      Int        @default(0) // بالثواني
  order         Int
  isFree        Boolean    @default(false) // متاحة للمعاينة
  attachments   Json?      // [{name, url, size}]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module      Module?          @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  progress    LessonProgress[]
  videoTokens VideoToken[]

  @@index([courseId, order])
}

// ============ تسجيل الطلاب ============
model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  expiresAt   DateTime? // اختياري للوصول المؤقت

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

// ============ تتبع التقدم ============
model LessonProgress {
  id              String    @id @default(cuid())
  userId          String
  lessonId        String
  isCompleted     Boolean   @default(false)
  watchedSeconds  Int       @default(0)
  lastPosition    Int       @default(0) // resume watching
  watchCount      Int       @default(0)
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([userId, isCompleted])
  @@index([lessonId])
}

// ============ توكنات الفيديو (للأمان) ============
model VideoToken {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  token     String   @unique
  ipAddress String?
  expiresAt DateTime
  usedCount Int      @default(0)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

// ============ المدفوعات ============
model Payment {
  id              String        @id @default(cuid())
  userId          String
  courseId        String
  amount          Int           // بالقرش
  currency        String        @default("EGP")
  status          PaymentStatus @default(PENDING)
  method          String?       // card, wallet, fawry
  paymobOrderId   String?       @unique
  paymobTxnId     String?       @unique
  couponCode      String?
  discount        Int           @default(0) // مبلغ الخصم بالقرش
  metadata        Json?
  createdAt       DateTime      @default(now())
  paidAt          DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  commission Commission?

  @@index([userId])
  @@index([status])
  @@index([status, createdAt])
  @@index([userId, courseId, status])
}

// ============ عمولات الإحالة (Affiliate Commissions) ============
model Commission {
  id             String           @id @default(cuid())
  referrerId     String // المستخدم اللي بياخد العمولة
  referredUserId String // المستخدم اللي اشترى
  paymentId      String           @unique // عمولة واحدة لكل دفعة (يمنع الازدواج)
  amount         Int // العمولة بالقرش
  rate           Int // نسبة العمولة وقت التسجيل (%)
  status         CommissionStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  paidAt         DateTime?

  referrer User    @relation("CommissionReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  payment  Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([referrerId, status])
  @@index([status, createdAt])
}

enum CommissionStatus {
  PENDING // مستحقة
  PAID // اتدفعت
  CANCELLED // اتلغت (مثلاً استرجاع)
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    @default("percentage") // percentage | fixed
  discountValue Int       // نسبة مئوية أو مبلغ بالقرش
  maxUses       Int?      // null = unlimited
  usedCount     Int       @default(0)
  minPrice      Int?      // أقل مبلغ للتطبيق (بالقرش)
  courseId      String?   // null = ينطبق على كل الكورسات
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  course Course? @relation(fields: [courseId], references: [id])
}

// ============ التقييمات ============
model Rating {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  rating    Int      // 1-5
  comment   String?  @db.Text
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

// ============ المجتمع ============
model Post {
  id            String   @id @default(cuid())
  userId        String
  courseId      String?  // اختياري - منشور في كورس معين
  content       String   @db.Text
  image         String?
  mediaUrl      String?   // رابط الصورة أو الفيديو
  mediaType     String?   // "image" أو "video"
  likesCount    Int      @default(0)
  commentsCount Int      @default(0)
  isPinned      Boolean  @default(false)
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course?    @relation(fields: [courseId], references: [id], onDelete: SetNull)
  comments  Comment[]
  likes     Like[]
  reactions Reaction[]

  @@index([courseId, createdAt])
  @@index([userId])
  @@index([isDeleted, isPinned, createdAt])
}

model Comment {
  id         String   @id @default(cuid())
  postId     String
  userId     String
  parentId   String?  // للردود على كومنت
  content    String   @db.Text
  likesCount Int      @default(0)
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  post      Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]  @relation("CommentReplies")
  likes     Like[]
  reactions Reaction[]

  @@index([postId])
  @@index([parentId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String?
  commentId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
}

model Reaction {
  id        String   @id @default(cuid())
  userId    String
  postId    String?
  commentId String?
  type      String   // "like" | "love" | "haha" | "wow" | "sad"
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([postId, type])
  @@index([commentId])
}

// ============ الإشعارات ============
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String?          @db.Text
  link      String?
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

enum NotificationType {
  LIKE
  COMMENT
  ENROLLMENT
  COURSE_UPDATE
  NEW_LESSON
  CERTIFICATE
  PAYMENT_SUCCESS
  SYSTEM
}

// ============ الشهادات ============
model Certificate {
  id              String   @id @default(cuid())
  userId          String
  courseId        String
  certificateCode String   @unique
  issuedAt        DateTime @default(now())
  pdfUrl          String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

// ============ المدونة ============
model BlogPost {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String?   @db.Text // ملخص قصير للمقال
  content       String    @db.Text // المحتوى بالـ Markdown
  thumbnail     String?
  category      String    // مثلاً: "تصميم", "AI", "فريلانس", "مهارات"
  tags          String[]  // كلمات مفتاحية
  authorId      String
  isPublished   Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  viewsCount    Int       @default(0)
  readingTime   Int       @default(0) // بالدقايق
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  author       User          @relation("BlogAuthor", fields: [authorId], references: [id])
  comments     BlogComment[]
  likes        BlogLike[]

  @@index([isPublished, isFeatured, publishedAt])
  @@index([category])
  @@index([slug])
}

model BlogComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  parentId  String?
  content   String   @db.Text
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User          @relation("BlogCommentAuthor", fields: [userId], references: [id], onDelete: Cascade)
  parent  BlogComment?  @relation("BlogCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies BlogComment[] @relation("BlogCommentReplies")

  @@index([postId, createdAt])
  @@index([parentId])
}

model BlogLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation("BlogLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}
